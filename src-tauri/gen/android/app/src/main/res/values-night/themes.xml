<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.chatto_desktop" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/chatto_background_dark</item>
    </style>

    <!-- Dark-mode launch splash, same structure as the light variant. -->
    <style name="Theme.chatto_desktop.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/chatto_background_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.chatto_desktop</item>
    </style>
</resources>
